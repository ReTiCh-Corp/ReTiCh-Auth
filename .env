# Server
PORT=8081
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=ydgduhghdjghsgdkeghsggjhsgdjhdsgjhsdgjhgsdjhg
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=168h

# Resend (https://resend.com)
RESEND_API_KEY=re_iRrHpnd1_8wkMwETiAhS1XLAxc61Padct
RESEND_FROM_EMAIL=noreply@nanobannana.fr
RESEND_FROM_NAME=ReTiCh Auth

# App
APP_URL=http://localhost:8081
# En dev sans frontend, FRONTEND_URL pointe directement sur l'API
# En prod, mettre l'URL du frontend : FRONTEND_URL=https://monapp.com
# URLs autorisées pour redirect_url (séparées par virgule) — sécurité anti-phishing
ALLOWED_REDIRECT_URLS=http://localhost:3000,http://localhost:8081/api/v1/auth
ALLOWED_ORIGINS=http://localhost:3000

# Security
BCRYPT_COST=12
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m
EMAIL_VERIFICATION_EXPIRY=24h
PASSWORD_RESET_EXPIRY=1h
MAGIC_LINK_EXPIRY=15m
# false = connexion autorisée sans vérifier l'email (utile avec magic link)
REQUIRE_EMAIL_VERIFICATION=true
