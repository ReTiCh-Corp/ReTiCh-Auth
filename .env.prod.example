# Production secrets — copier en .env.prod et remplir les valeurs
# NE JAMAIS commiter .env.prod

POSTGRES_PASSWORD=

# Générer : openssl genrsa 2048 | awk 'NF {sub(/\r/,""); printf "%s\\n",$0}'
RSA_PRIVATE_KEY=

# Générer : openssl rand -hex 32
ADMIN_API_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tondomaine.com
RESEND_FROM_NAME=ReTiCh Auth

# Générer : openssl rand -base64 32
SESSION_SECRET=

APP_URL=https://auth.tondomaine.com
ALLOWED_ORIGINS=https://tonapp.com
ALLOWED_REDIRECT_URLS=https://tonapp.com/callback
