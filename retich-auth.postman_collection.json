                { "key": "redirect_uri", "value": "http://localhost:5173/callback" },
                { "key": "client_id", "value": "{{client_id}}" },
                { "key": "client_secret", "value": "{{client_secret}}" },
                { "key": "code_verifier", "value": "{{code_verifier}}" }
              ]
            },
            "description": "Uses {{oauth_code}} captured from step 2 and {{code_verifier}} from step 1."
          }
        },
        {
          "name": "4. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
