# Server
PORT=8081
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-at-least-32-random-bytes
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=168h

# Resend (https://resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=ReTiCh Auth

# App
APP_URL=http://localhost:8081
# FRONTEND_URL=https://monapp.com
# URLs autorisées pour redirect_url (séparées par virgule)
ALLOWED_REDIRECT_URLS=https://app-shop.com,https://app-blog.com
ALLOWED_ORIGINS=http://localhost:3000

# Security
BCRYPT_COST=12
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m
EMAIL_VERIFICATION_EXPIRY=24h
PASSWORD_RESET_EXPIRY=1h
