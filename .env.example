# Server
PORT=8081
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth?sslmode=disable

# JWT (RS256)
# Générer la clé: openssl genrsa 2048 | awk 'NF {sub(/\r/,""); printf "%s\\n",$0}'
# En dev: laisser vide → clé éphémère générée automatiquement (tokens invalidés au restart)
RSA_PRIVATE_KEY=
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=168h

# Resend (https://resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=ReTiCh Auth

# App
APP_URL=http://localhost:8081
# URLs autorisées pour redirect_url (séparées par virgule) — sécurité anti-phishing
ALLOWED_REDIRECT_URLS=http://localhost:3000,http://localhost:5173/callback
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
BCRYPT_COST=12
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m
EMAIL_VERIFICATION_EXPIRY=24h
PASSWORD_RESET_EXPIRY=1h
MAGIC_LINK_EXPIRY=15m
REQUIRE_EMAIL_VERIFICATION=true

# OAuth 2.0 / OIDC
# Générer: openssl rand -hex 32
ADMIN_API_KEY=change-me-admin-key
# Générer: openssl rand -base64 32
SESSION_SECRET=change-me-in-production-at-least-32-bytes
SESSION_EXPIRY=24h
